{
  "global_tags": {
    "owning_team": "OHAI",
    "Environment": "development",
    "Department": "product",
    "Product": "OHAI"
  },
  "resources": [
    {
      "id": "host1",
      "provider": "aws",
      "type": "ec2",
      "size": "t3.small",
      "ami_name": "al2023-ami-2023*-x86_64",
      "user_name": "ec2-user"
    }
  ],
  "services": [
    {
      "id": "haproxy1",
      "destinations": [
        "host1"
      ],
      "source_repository": "https://github.com/newrelic/open-install-library.git",
      "deploy_script_path": "test/deploy/linux/nrdot-haproxy/install/rhel/roles",
      "port": 8404
    }
  ],
  "instrumentations": {
    "resources": [
      {
        "id": "nr_nrdot_haproxy_al2023_amd64",
        "resource_ids": [
          "host1"
        ],
        "source_repository": "https://github.com/newrelic/open-install-library.git",
        "deploy_script_path": "test/deploy/linux/newrelic-cli/install-recipe/roles",
        "params": {
          "recipe_content_url": "https://raw.githubusercontent.com/newrelic/open-install-library/main/recipes/newrelic/infrastructure/nrdot/haproxy/rhel.yml",
          "recipe_targeted": "nrdot-collector-haproxy",
          "validate_output": "NRDOT Collector - HAProxy\\s+\\(installed\\)",
          "env_var": "NEW_RELIC_CLI_SKIP_CORE=1 NR_CLI_HAPROXY_STATS_URL=http://127.0.0.1:8404/stats"
        },
        "provider": "newrelic"
      }
    ]
  }
}
