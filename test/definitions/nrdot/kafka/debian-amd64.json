{
  "global_tags": {
    "owning_team": "jumpstart",
    "Environment": "development",
    "Department": "product",
    "Product": "jumpstart"
  },
  "resources": [
    {
      "id": "host1",
      "provider": "aws",
      "type": "ec2",
      "size": "t3.small",
      "ami_name": "debian-12-amd64-daily-202?????-*",
      "user_name": "admin"
    }
  ],
  "services": [
    {
      "id": "kafka1",
      "destinations": ["host1"],
      "source_repository": "-b nrdot-kafka-recipe https://github.com/newrelic/open-install-library.git",
      "deploy_script_path": "test/deploy/linux/nrdot-kafka/install/roles",
      "port": 9092
    }
  ],
  "instrumentations": {
    "resources": [
      {
        "id": "nr_nrdot_kafka_debian_amd64",
        "resource_ids": ["host1"],
        "provider": "opentelemetry",
        "source_repository": "-b nrdot-kafka-recipe https://github.com/newrelic/open-install-library.git",
        "deploy_script_path": "test/deploy/linux/newrelic-cli/install-recipe/roles",
        "params": {
          "recipe_content_url": "https://raw.githubusercontent.com/newrelic/open-install-library/main/recipes/newrelic/infrastructure/nrdot/kafka/debian.yml",
          "validate_output": "NRDOT Collector is running",
          "recipe_targeted": "nrdot-kafka",
          "env_vars": "NR_CLI_KAFKA_CLUSTER_NAME=kafka-test-cluster NR_CLI_KAFKA_BOOTSTRAP_BROKERS=localhost:9092,localhost:9093"
        }
      }
    ]
  }
}
