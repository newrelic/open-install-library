{
  "global_tags": {
    "owning_team": "OHAI",
    "Environment": "development",
    "Department": "product",
    "Product": "OHAI"
  },
  "resources": [
    {
      "id": "host1",
      "provider": "aws",
      "type": "ec2",
      "size": "t3.small",
      "ami_name": "al2023-ami-2023.*-x86_64",
      "user_name": "ec2-user"
    }
  ],
  "services": [
    {
      "id": "kafka1",
      "destinations": [
        "host1"
      ],
      "source_repository": "-b nrdot-kafka-recipe-tests https://github.com/newrelic/open-install-library.git",
      "deploy_script_path": "test/deploy/linux/nrdot-kafka/install/rhel/roles",
      "port": 9092
    }
  ],
  "instrumentations": {
    "resources": [
      {
        "id": "nr_nrdot_kafka_al2023_amd64",
        "resource_ids": [
          "host1"
        ],
        "source_repository": "-b nrdot-kafka-recipe https://github.com/newrelic/open-install-library.git",
        "deploy_script_path": "test/deploy/linux/newrelic-cli/install-recipe/roles",
        "params": {
          "recipe_content_url": "https://raw.githubusercontent.com/newrelic/open-install-library/nrdot-kafka-recipe/recipes/newrelic/infrastructure/nrdot/kafka/rhel.yml",
          "recipe_targeted": "nrdot-kafka",
          "validate_output": "NRDOT Collector is running"
        },
        "provider": "newrelic"
      }
    ]
  }
}
