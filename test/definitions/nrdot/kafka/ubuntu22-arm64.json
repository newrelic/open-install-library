{
  "global_tags": {
    "owning_team": "OHAI",
    "Environment": "development",
    "Department": "product",
    "Product": "OHAI"
  },
  "resources": [
    {
      "id": "host1",
      "provider": "aws",
      "type": "ec2",
      "size": "t4g.medium",
      "ami_name": "ubuntu/images/hvm-ssd/ubuntu-jammy-22.04-arm64-server-????????",
      "user_name": "ubuntu"
    }
  ],
  "services": [
    {
      "id": "kafka1",
      "destinations": [
        "host1"
      ],
      "source_repository": "https://github.com/newrelic/open-install-library.git",
      "deploy_script_path": "test/deploy/linux/nrdot-kafka/install/debian/roles",
      "port": 9092
    }
  ],
  "instrumentations": {
    "resources": [
      {
        "id": "nr_nrdot_kafka_ubuntu22_arm64",
        "resource_ids": [
          "host1"
        ],
        "source_repository": "https://github.com/newrelic/open-install-library.git",
        "deploy_script_path": "test/deploy/linux/newrelic-cli/install-recipe/roles",
        "params": {
          "recipe_content_url": "https://raw.githubusercontent.com/newrelic/open-install-library/main/recipes/newrelic/infrastructure/nrdot/kafka/debian.yml",
          "recipe_targeted": "nrdot-kafka",
          "validate_output": "NRDOT Kafka\\s+\\(installed\\)",
          "env_var": "NEW_RELIC_CLI_SKIP_CORE=1 NR_CLI_KAFKA_CLUSTER_NAME=kafka-ubuntu22-arm64-cluster NR_CLI_KAFKA_BOOTSTRAP_BROKERS=localhost:9092"
        },
        "provider": "newrelic"
      }
    ]
  }
}