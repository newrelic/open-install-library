{
  "global_tags": {
    "owning_team": "OHAI",
    "Environment": "development",
    "Department": "product",
    "Product": "OHAI"
  },
  "resources": [
    {
      "id": "host1",
      "provider": "aws",
      "type": "ec2",
      "size": "t3.small",
      "ami_name": "ubuntu/images/hvm-ssd/ubuntu-jammy-22.04-amd64-server-????????",
      "user_name": "ubuntu"
    }
  ],
  "services": [
    {
      "id": "kafka1",
      "destinations": [
        "host1"
      ],
      "source_repository": "-b nrdot-kafka-recipe-validate https://github.com/newrelic/open-install-library.git",
      "deploy_script_path": "test/deploy/linux/nrdot-kafka/install/debian/roles",
      "port": 9092,
      "instrumentation": {
        "type": "cli",
        "command": "sudo NEW_RELIC_API_KEY=$NEW_RELIC_API_KEY NEW_RELIC_ACCOUNT_ID=$NEW_RELIC_ACCOUNT_ID NR_CLI_KAFKA_CLUSTER_NAME=kafka-cluster NR_CLI_KAFKA_BOOTSTRAP_BROKERS=localhost:9092 NR_CLI_MONITORING_LEVEL=complete /usr/local/bin/newrelic install -n nrdot-kafka"
      }
    }
  ]
}
