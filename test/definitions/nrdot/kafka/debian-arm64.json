{
  "global_tags": {
    "owning_team": "ohai",
    "Environment": "development",
    "Department": "product",
    "Product": "jumpstart"
  },
  "resources": [
    {
      "id": "host1",
      "provider": "aws",
      "type": "ec2",
      "size": "t4g.small",
      "ami_name": "debian-12-arm64-daily-202?????-*",
      "user_name": "admin"
    }
  ],
  "services": [
    {
      "id": "kafka1",
      "destinations": [
        "host1"
      ],
      "source_repository": "-b nrdot-kafka-recipe-tests https://github.com/newrelic/open-install-library.git",
      "deploy_script_path": "test/deploy/linux/nrdot-kafka/install/debian/roles",
      "port": 9092
    }
  ],
  "instrumentations": {
    "resources": [
      {
        "id": "nr_nrdot_kafka_debian_arm64",
        "resource_ids": [
          "host1"
        ],
        "source_repository": "-b nrdot-kafka-recipe https://github.com/newrelic/open-install-library.git",
        "deploy_script_path": "test/deploy/linux/newrelic-cli/install-recipe/roles",
        "params": {
          "recipe_content_url": "https://raw.githubusercontent.com/newrelic/open-install-library/main/recipes/newrelic/infrastructure/nrdot/kafka/debian.yml",
          "recipe_targeted": "nrdot-kafka"
        }
      }
    ]
  }
}
