{
  "global_tags": {
    "owning_team": "OHAI",
    "Environment": "development",
    "Department": "product",
    "Product": "OHAI"
  },
  "resources": [
    {
      "id": "host1",
      "provider": "aws",
      "type": "ec2",
      "size": "t3.small",
      "ami_name": "amzn2-ami-hvm-2.0.*-x86_64-gp2",
      "user_name": "ec2-user"
    }
  ],
  "services": [
    {
      "id": "elasticsearch1",
      "destinations": [
        "host1"
      ],
      "source_repository": "-b feature/es-otel-recipie-changes https://github.com/newrelic/open-install-library.git",
      "deploy_script_path": "test/deploy/linux/elasticsearch-otel/install/rhel/roles",
      "port": 9200
    }
  ],
  "instrumentations": {
    "resources": [
      {
        "id": "nr_nrdot_elasticsearch_al2_amd64",
        "resource_ids": [
          "host1"
        ],
        "source_repository": "-b feature/es-otel-recipie-changes https://github.com/newrelic/open-install-library.git",
        "deploy_script_path": "test/deploy/linux/newrelic-cli/install-recipe/roles",
        "params": {
          "recipe_content_url": "https://raw.githubusercontent.com/newrelic/open-install-library/feature/es-otel-recipie-changes/recipes/newrelic/infrastructure/nrdot/elasticsearch-otel/rhel.yml",
          "recipe_targeted": "elasticsearch-otel-integration",
          "validate_output": "Elasticsearch OpenTelemetry Integration\\s+\\(installed\\)",
          "env_var": "NEW_RELIC_CLI_SKIP_CORE=1 NR_CLI_ES_CLUSTER_NAME=test-elasticsearch-cluster"
        },
        "provider": "newrelic"
      }
    ]
  }
}
